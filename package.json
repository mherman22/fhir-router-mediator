{
  "name": "fhir-router-mediator",
  "version": "1.0.0",
  "description": "OpenHIM mediator that routes a FHIR transaction Bundle by resource type: Patient identities to the Client Registry (OpenCR), clinical resources to the Shared Health Record (SHR)",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0",
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "openhim-mediator-utils": "^0.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "prettier": "^3.2.0",
    "supertest": "^6.3.0"
  }
}
